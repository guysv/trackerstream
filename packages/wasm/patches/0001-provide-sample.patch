+/*! \brief Overwrite one sample's decoded PCM in place (trackerstream streaming fork)
+ *
+ * Copies \a frames frames of native-layout decoded PCM (matching the ModSample's
+ * bit depth / channel interleave exactly) over the already-allocated sample
+ * buffer of sample \a sample_index, then rebuilds that sample's loop /
+ * interpolation lookahead. The sample must already have been allocated at this
+ * exact length by the loader (the streaming "skeleton" declares uncompressed PCM
+ * of the decoded length). Must be called single-threaded with respect to
+ * rendering (e.g. from the worklet between process() quanta).
+ *
+ * \param mod The module handle to work on.
+ * \param sample_index The 1-based sample slot to patch.
+ * \param data Native-layout decoded PCM, \a frames frames long.
+ * \param frames Number of frames; must equal the sample's declared length.
+ * \return 1 on success, 0 on failure (bad index, unallocated slot, length mismatch).
+ */
+LIBOPENMPT_API int openmpt_module_provide_sample( openmpt_module * mod, int32_t sample_index, const void * data, size_t frames );
+/*! \brief Query whether a sample still needs its PCM provided (trackerstream fork)
+ *
+ * \param mod The module handle to work on.
+ * \param sample_index The 1-based sample slot to query.
+ * \return 1 if the sample has not yet been provided via openmpt_module_provide_sample, 0 otherwise.
+ */
+LIBOPENMPT_API int openmpt_module_is_sample_pending( openmpt_module * mod, int32_t sample_index );
+/*! \brief Debug/harness only: pointer to a sample's decoded PCM buffer (trackerstream fork)
