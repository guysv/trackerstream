@@ -1425,6 +1425,56 @@ std::int32_t module_impl::get_num_instruments() const {
 std::int32_t module_impl::get_num_samples() const {
 	return m_sndFile->GetNumSamples();
 }
+bool module_impl::provide_sample( std::int32_t index, const void * data, std::size_t frames ) {
+	// trackerstream streaming fork: patch decoded PCM into an immortal instance.
+	if ( !data ) {
+		return false;
+	}
+	if ( index < 1 || index > m_sndFile->GetNumSamples() ) {
+		return false;
+	}
+	OpenMPT::ModSample & smp = m_sndFile->GetSample( static_cast<OpenMPT::SAMPLEINDEX>( index ) );
+	// The skeleton's stock load already allocated the full-length, guard-padded
+	// buffer; provide_sample must match that declared length exactly.
+	if ( smp.sampleb() == nullptr || smp.nLength == 0 ) {
+		return false;
+	}
+	if ( frames != static_cast<std::size_t>( smp.nLength ) ) {
+		return false;
+	}
+	std::memcpy( smp.sampleb(), data, smp.GetSampleSizeInBytes() );
+	// Rebuild the interpolation guard / loop wrap-around buffers for the new PCM.
+	smp.PrecomputeLoops( *m_sndFile, false );
+	if ( m_sample_provided.size() <= static_cast<std::size_t>( index ) ) {
+		m_sample_provided.resize( static_cast<std::size_t>( m_sndFile->GetNumSamples() ) + 1, false );
+	}
+	m_sample_provided[ index ] = true;
+	return true;
+}
+bool module_impl::is_sample_pending( std::int32_t index ) const {
+	if ( index < 1 || index > m_sndFile->GetNumSamples() ) {
+		return false;
+	}
+	return index >= static_cast<std::int32_t>( m_sample_provided.size() ) || !m_sample_provided[ index ];
+}
+const void * module_impl::debug_sample_data( std::int32_t index ) const {
+	if ( index < 1 || index > m_sndFile->GetNumSamples() ) {
+		return nullptr;
+	}
+	return m_sndFile->GetSample( static_cast<OpenMPT::SAMPLEINDEX>( index ) ).samplev();
+}
+std::size_t module_impl::debug_sample_bytes( std::int32_t index ) const {
+	if ( index < 1 || index > m_sndFile->GetNumSamples() ) {
+		return 0;
+	}
+	return m_sndFile->GetSample( static_cast<OpenMPT::SAMPLEINDEX>( index ) ).GetSampleSizeInBytes();
+}
+std::size_t module_impl::debug_sample_frames( std::int32_t index ) const {
+	if ( index < 1 || index > m_sndFile->GetNumSamples() ) {
+		return 0;
+	}
+	return m_sndFile->GetSample( static_cast<OpenMPT::SAMPLEINDEX>( index ) ).nLength;
+}
 
