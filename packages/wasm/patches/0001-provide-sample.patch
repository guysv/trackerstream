+ */
+LIBOPENMPT_API const void * openmpt_module_debug_sample_data( openmpt_module * mod, int32_t sample_index );
+/*! \brief Debug/harness only: byte size of a sample's decoded PCM buffer (trackerstream fork)
+ *
+ * \param mod The module handle to work on.
+ * \param sample_index The 1-based sample slot.
+ * \return Number of bytes (frames * bytes-per-frame), or 0 on error.
+ */
+LIBOPENMPT_API size_t openmpt_module_debug_sample_bytes( openmpt_module * mod, int32_t sample_index );
+/*! \brief Debug/harness only: frame count (nLength) of a sample (trackerstream fork)
+ *
+ * \param mod The module handle to work on.
+ * \param sample_index The 1-based sample slot.
+ * \return Number of frames, or 0 on error.
