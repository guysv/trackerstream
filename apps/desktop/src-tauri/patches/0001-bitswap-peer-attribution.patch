+// trackerstream patch: per-peer Bitswap byte accounting. Counted at the two
+// points where block PAYLOADS actually cross the wire — inbound `put_block`
+// (down) and the outbound `HaveSessionEvent::Block` response (up) — so the totals
+// reflect real per-peer block transfer. A process-global snapshot map, polled by
+// the app (no swarm-command plumbing needed). See patches/0001-*.patch.
+static BANDWIDTH: std::sync::OnceLock<std::sync::Mutex<HashMap<PeerId, (u64, u64)>>> =
+    std::sync::OnceLock::new();
+
+fn bandwidth_map() -> &'static std::sync::Mutex<HashMap<PeerId, (u64, u64)>> {
+    BANDWIDTH.get_or_init(Default::default)
+}
+
+fn record_down(peer: PeerId, bytes: usize) {
+    bandwidth_map().lock().unwrap().entry(peer).or_default().0 += bytes as u64;
+}
+
+fn record_up(peer: PeerId, bytes: usize) {
+    bandwidth_map().lock().unwrap().entry(peer).or_default().1 += bytes as u64;
+}
+
+/// Cumulative `(down, up)` Bitswap block bytes per peer since process start.
+pub fn bandwidth_snapshot() -> HashMap<PeerId, (u64, u64)> {
+    bandwidth_map().lock().unwrap().clone()
+}
