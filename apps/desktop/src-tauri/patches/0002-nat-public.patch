+    /// AutoNAT's public-reachability verdict, reduced to a `bool` so callers need no
+    /// `libp2p` dependency: `true` once AutoNAT has confirmed a public address, `false`
+    /// while it believes the node is private OR hasn't decided yet (`Private`/`Unknown`
+    /// collapse together — the only boundary that matters for relay eligibility and
+    /// self-reservation is public-vs-not). AutoNAT flips on probe results, so callers
+    /// should debounce. Unlike `external_addresses`, this can't be fooled by our own
+    /// relay-circuit or identify-observed addrs. trackerstream patch (R2 eligibility gate).
+    pub async fn nat_public(&self) -> Result<bool, Error> {
+        self.connexa
+            .autonat()
+            .nat_status()
+            .await
+            .map(|status| status.is_public())
+            .map_err(Into::into)
+    }
