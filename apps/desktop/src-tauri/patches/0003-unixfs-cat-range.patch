+    /// Restrict the cat to a byte range of the file (trackerstream patch, R1): exposes the
+    /// existing `range` field so a SQLite-over-Bitswap VFS can fetch only the pages a query
+    /// touches instead of the whole DB. `IdleFileVisit::with_target_range` already consumes
+    /// `self.range` in `poll_next`; only this public setter was missing.
+    pub fn range(mut self, range: Range<u64>) -> Self {
+        self.range = Some(range);
+        self
+    }
