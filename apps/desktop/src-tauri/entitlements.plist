<?xml version="1.0" encoding="UTF-8"?>
<!-- macOS hardened-runtime entitlements (required for notarization, D2).
     The embedded libopenmpt WASM (WKWebView + AudioWorklet) needs JIT / writable
     executable memory; the embedded rust-ipfs node makes outbound network
     connections. Referenced from tauri.conf.json bundle.macOS.entitlements and
     applied when the app is codesigned with a Developer ID. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
