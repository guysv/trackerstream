# trackerstream server config (installed to /etc/trackerstream/server.env).
# Secrets/config live OUTSIDE the deploy artifact.
CORPUS=/srv/trackerstream/archive
CATALOG_DB=/srv/trackerstream/catalog/catalog.db
KUBO_API=http://127.0.0.1:5001
API_PORT=8080
# Limit ingest to the parser-covered formats by default (mptm/mo3 fall back to
# flat DAGs automatically). Leave unset to ingest everything found.
FORMATS=mod,it,s3m,xm,mptm,mo3
