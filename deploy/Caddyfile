# trackerstream TLS endpoint (static).
#
# The Node.js control-plane API was retired with the Go cutover: catalog/search and
# IPNS distribution moved entirely into libp2p (custom DHT + gossipsub on tsnode), and
# clients no longer make any HTTPS request to the box. Caddy is kept ONLY to hold a
# valid cert + a 200 on :443 for the domain (uptime probes, ACME renewal) — there is no
# backend to proxy anymore. coturn/STUN (:3478) and the libp2p swarm (:4001) are direct,
# not behind Caddy.
#
# This is a TEMPLATE: deploy/setup-tls.sh renders ${TS_DOMAIN} (envsubst) to the
# literal hostname into /etc/caddy/Caddyfile before starting Caddy. To run by hand:
#
#   TS_DOMAIN=trackerstream.xyz envsubst '${TS_DOMAIN}' < deploy/Caddyfile | caddy run --config -
#
# Caddy needs :80 (ACME HTTP-01 challenge + HTTP->HTTPS redirect) and :443.

${TS_DOMAIN} {
	encode zstd gzip
	respond /healthz "ok" 200
	respond "trackerstream" 200
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		-Server
	}
	# Access logs go to journald (the default) — kept inside Caddy's systemd
	# sandbox, retention via journald (see deploy/backup.sh / D3 log rotation).
}
